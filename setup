#!/usr/bin/env bash

echo """
-------------------------------------------------------------
                    Setup Initiated 
-------------------------------------------------------------
"""

config_location=$HOME/.config/config

# Delete older config if exist
rm -f $config_location

# Install starship
brew install starship

#install iterm2 --No
brew install --cask iterm2

#install neovim
brew install neovim

#install ripgrep
brew install ripgrep

#install tree
brew install tree

#install fzf
brew install fzf

#install font-fira-code -- install unzip first
brew install font-fira-code

#install ghostty -- No
brew install --cask ghostty
source ./ghostty/setup

#install tmux
brew install tmux
source ./tmux/setup

#Create exportable config file for .zshrc
touch $config_location
echo '''#!/usr/bin/env bash

# This is an auto generated file. Please do not edit manually.

# Import initial terminal prompt
#source $HOME/.config/zsh_scripts/simple_terminal_prompt

# Alias
source $HOME/.config/zsh_scripts/aliases

# Misc config
source $HOME/.config/zsh_scripts/misc_configs

# Starship Config
export STARSHIP_CONFIG="$HOME/.config/starship/starship.toml" 
eval "$(starship init zsh)"

# fzf config to set up fzf key bindings and fuzzy completion
source <(fzf --zsh)

''' >> $config_location

# Create .gitconfig
echo '''
[user]
    email = praanshugrover60@gmail.com
    name = Praanshu Grover
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[core]
    editor = nvim
[init]
    defaultBranch = master
''' >> $HOME/.gitconfig

# END 
echo """
-------------------------------------------------------------
        Setup complete | Reload .zshrc 
-------------------------------------------------------------
"""
